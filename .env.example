DEEPSEEK_API_KEY=your_deepseek_api_key
MODEL_NAME=deepseek-chat
PORT=3001
# Optional: max successful chat requests per IP each day. Defaults to 20.
# DAILY_CHAT_LIMIT=20
# Optional: natural-day timezone used by the daily limit. Defaults to Asia/Shanghai.
# DAILY_CHAT_LIMIT_TIMEZONE=Asia/Shanghai
# Optional: defaults to 0.0.0.0 in production.
# HOST=0.0.0.0
# Optional: only set this when frontend and backend are on different origins.
# CLIENT_ORIGIN=https://your-frontend-domain.com
